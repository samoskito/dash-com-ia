NODE_ENV=development
WEB_ORIGIN=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:3333
API_PUBLIC_URL=https://wpptrack-api.rastrack.app
API_PORT=3333
WPPTRACK_API_SLOW_REQUEST_MS=1500
WPPTRACK_API_SLOW_REPORT_QUERY_MS=750
WPPTRACK_WEB_SLOW_REQUEST_MS=1500
WPPTRACK_WEB_PROVIDER_STATUS_TIMEOUT_MS=2000
WPPTRACK_EXTERNAL_SYNC_ENABLED=true
WPPTRACK_EXTERNAL_SYNC_INTERVAL_MINUTES=1
WPPTRACK_EXTERNAL_SYNC_INITIAL_DELAY_SECONDS=60
WPPTRACK_EXTERNAL_SYNC_CONNECTOR_LIMIT=50
WPPTRACK_EXTERNAL_SYNC_ROW_BATCH_SIZE=200
WPPTRACK_EXTERNAL_MYSQL_CONNECT_TIMEOUT_MS=5000
WPPTRACK_EXTERNAL_MYSQL_QUERY_TIMEOUT_MS=10000

DATABASE_URL=postgresql://wpptrack:wpptrack@localhost:5432/wpptrack
REDIS_URL=redis://localhost:6379
EXTERNAL_CONNECTOR_ENCRYPTION_KEY=replace-me-external-connector-encryption-key

JWT_ACCESS_SECRET=replace-me-access-secret
JWT_REFRESH_SECRET=replace-me-refresh-secret
AUTH_PUBLIC_REGISTRATION_ENABLED=false
AUTH_COOKIE_DOMAIN=.rastrack.app
AUTH_EXPOSE_DEV_TOKENS=false
EMAIL_PROVIDER=

WPPTRACK_PLATFORM_ADMIN_EMAILS=
WPPTRACK_WHATSAPP_INSTANCE_PRICE_CENTS=9900

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3333/auth/google/callback
GOOGLE_OAUTH_STATE_SECRET=replace-me-google-state-secret

META_APP_ID=
META_APP_SECRET=
META_OAUTH_REDIRECT_URL=https://wpptrack-api.rastrack.app/integrations/meta/callback
META_GRAPH_API_VERSION=v25.0
META_OAUTH_SCOPES=ads_read,ads_management,business_management,pages_show_list,pages_read_engagement
META_TOKEN_ENCRYPTION_KEY=replace-me-meta-token-encryption-key
META_WEBHOOK_VERIFY_TOKEN=
WPPTRACK_META_AUTO_SYNC_ENABLED=true
WPPTRACK_META_AUTO_SYNC_INTERVAL_MINUTES=180
WPPTRACK_META_AUTO_SYNC_INITIAL_DELAY_SECONDS=60
WPPTRACK_META_AUTO_SYNC_LOOKBACK_DAYS=7
WPPTRACK_META_AUTO_SYNC_BATCH_LIMIT=100
WPPTRACK_REPORT_TIMEZONE=America/Sao_Paulo

UAZAPI_BASE_URL=
UAZAPI_ADMIN_TOKEN=
UAZAPI_TOKEN=
UAZAPI_WEBHOOK_AUTH_TOKEN=

ASAAS_BASE_URL=https://sandbox.asaas.com/api/v3
ASAAS_API_KEY=
ASAAS_WEBHOOK_AUTH_TOKEN=
