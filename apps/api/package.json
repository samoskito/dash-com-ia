{
  "name": "@wpptrack/api",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "dev": "node --watch -r ts-node/register src/main.ts",
    "build": "nest build",
    "start": "node dist/apps/api/src/main.js",
