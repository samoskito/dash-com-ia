generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum WorkspaceRole {
  owner
  admin
  member
}

enum PlatformRole {
  platform_owner
  platform_operator
}

enum AuthProvider {
  email
  google
}

enum WorkspaceInviteStatus {
  pending
  accepted
  revoked
  expired
}

enum WorkspaceOperationalStatus {
  active
  blocked
}

enum WhatsappInstanceStatus {
  pending_payment
  active
  disconnected
  suspended
  error
}

enum DiagnosticSource {
  meta
  uazapi
  asaas
  external_mysql
  internal
}

enum DiagnosticSeverity {
  info
  warning
  error
  critical
}

enum PaymentChargeStatus {
  pending
  paid
  failed
  canceled
  expired
}

enum WhatsappInstanceActivationStatus {
  pending_payment
  active
  canceled
  expired
}

enum ConversionTriggerType {
  keyword
  whatsapp_label
}

enum ConversionMatchMode {
  contains
  exact
}

enum LeadStatus {
  new
  active
  qualified
  converted
  lost
}

enum MetaAssetSyncStatus {
  pending
  syncing
  synced
  error
}

enum MetaConversionDestinationStatus {
  needs_configuration
  configured
  error
}

enum MetaWhatsappClassification {
  auto_whatsapp
  creative_whatsapp
  detected_by_leads
  manual_include
  manual_exclude
  needs_review
  not_whatsapp
}

enum AuthActionTokenType {
  password_reset
  email_verification
}

model User {
  id              String        @id @default(cuid())
  email           String        @unique
  name            String?
  passwordHash    String?
  authProvider    AuthProvider  @default(email)
  googleId        String?       @unique
  emailVerifiedAt DateTime?
  platformRole    PlatformRole?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  memberships  WorkspaceMember[]
  sessions     AuthSession[]
  actionTokens AuthActionToken[]
  auditLogs    AuditLog[]
}

model Workspace {
  id                String                     @id @default(cuid())
  name              String
  slug              String                     @unique
  asaasCustomerId   String?
  operationalStatus WorkspaceOperationalStatus @default(active)
  createdAt         DateTime                   @default(now())
  updatedAt         DateTime                   @updatedAt

  members                     WorkspaceMember[]
  invites                     WorkspaceInvite[]
  whatsappInstances           WhatsappInstance[]
  diagnosticEvents            DiagnosticEvent[]
  webhookLogs                 WebhookLog[]
  integrationLogs             IntegrationLog[]
  conversionEventLogs         ConversionEventLog[]
  jobAttempts                 JobAttempt[]
  auditLogs                   AuditLog[]
  subscriptions               WorkspaceSubscription[]
  paymentCharges              PaymentCharge[]
  whatsappInstanceActivations WhatsappInstanceActivation[]
  conversionRules             ConversionRule[]
  funnelStageConfigurations   FunnelStageConfiguration[]
  leads                       Lead[]
  metaIntegration             MetaIntegration?
  metaAssetSnapshots          MetaAssetSnapshot[]
  metaConversionDestination   MetaConversionDestination?
  metaReportingAccounts       MetaReportingAccount[]
  metaCampaigns               MetaCampaign[]
  metaCampaignDailyInsights   MetaCampaignDailyInsight[]
  metaAdSets                  MetaAdSet[]
  metaAds                     MetaAd[]
  externalDataConnectors      ExternalDataConnector[]
  externalIngestionRecords    ExternalIngestionRecord[]
  supportSessions             AuthSession[]                @relation("AuthSessionSupportWorkspace")

  @@index([asaasCustomerId])
  @@index([operationalStatus])
}

model WorkspaceMember {
  id          String        @id @default(cuid())
  workspaceId String
  userId      String
  role        WorkspaceRole
  createdAt   DateTime      @default(now())

  workspace Workspace @relation(fields: [workspaceId], references: [id])
  user      User      @relation(fields: [userId], references: [id])

  @@unique([workspaceId, userId])
  @@index([userId])
}

model WhatsappInstance {
  id                     String                 @id @default(cuid())
  workspaceId            String
  name                   String
  provider               String
  providerInstanceId     String?
  providerTokenEncrypted String?
  providerTokenIv        String?
  providerTokenTag       String?
  webhookTokenHash       String?
  status                 WhatsappInstanceStatus @default(pending_payment)
  createdAt              DateTime               @default(now())
  updatedAt              DateTime               @updatedAt

  workspace   Workspace                    @relation(fields: [workspaceId], references: [id])
  activations WhatsappInstanceActivation[]
  leads       Lead[]

  @@index([workspaceId])
  @@index([providerInstanceId])
}

model AuthSession {
  id                        String    @id @default(cuid())
  userId                    String
  supportWorkspaceId        String?
  supportWorkspaceStartedAt DateTime?
  refreshHash               String    @unique
  userAgent                 String?
  ipAddress                 String?
  expiresAt                 DateTime
  revokedAt                 DateTime?
  createdAt                 DateTime  @default(now())

  user             User       @relation(fields: [userId], references: [id])
  supportWorkspace Workspace? @relation("AuthSessionSupportWorkspace", fields: [supportWorkspaceId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([supportWorkspaceId])
}

model AuthActionToken {
  id        String              @id @default(cuid())
  userId    String
  type      AuthActionTokenType
  tokenHash String              @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime            @default(now())

  user User @relation(fields: [userId], references: [id])

  @@index([userId, type, usedAt])
  @@index([type, expiresAt])
}

model WorkspaceInvite {
  id          String                @id @default(cuid())
  workspaceId String
  email       String
  role        WorkspaceRole
  status      WorkspaceInviteStatus @default(pending)
  tokenHash   String                @unique
  expiresAt   DateTime
  acceptedAt  DateTime?
  createdAt   DateTime              @default(now())

  workspace Workspace @relation(fields: [workspaceId], references: [id])

  @@index([workspaceId, email])
}

model WebhookLog {
  id              String           @id @default(cuid())
  workspaceId     String?
  source          DiagnosticSource
  eventType       String
  externalEventId String?
  status          String
  receivedAt      DateTime         @default(now())
  processedAt     DateTime?
  leadId          String?
  phoneHash       String?
  campaignId      String?
  adSetId         String?
  adId            String?
  jobId           String?
  errorCode       String?
  errorMessage    String?
  summaryPayload  Json?
  rawPayloadRef   String?
  idempotencyKey  String?          @unique

  workspace        Workspace?        @relation(fields: [workspaceId], references: [id])
  diagnosticEvents DiagnosticEvent[]

  @@index([workspaceId, source, status, receivedAt])
}

model IntegrationLog {
  id                   String           @id @default(cuid())
  workspaceId          String?
  source               DiagnosticSource
  operation            String
  status               String
  startedAt            DateTime         @default(now())
  finishedAt           DateTime?
  durationMs           Int?
  requestSummary       Json?
  responseSummary      Json?
  httpStatus           Int?
  providerRequestId    String?
  providerErrorCode    String?
  providerErrorMessage String?
  leadId               String?
  campaignId           String?
  adSetId              String?
  adId                 String?
  jobId                String?

  workspace        Workspace?        @relation(fields: [workspaceId], references: [id])
  diagnosticEvents DiagnosticEvent[]

  @@index([workspaceId, source, status, startedAt])
  @@index([providerRequestId])
}

model ConversionEventLog {
  id                      String    @id @default(cuid())
  workspaceId             String?
  leadId                  String?
  phoneHash               String?
  sourceTrigger           String
  eventName               String
  status                  String
  pixelId                 String?
  pageId                  String?
  eventId                 String?
  metaAccountId           String?
  campaignId              String?
  adSetId                 String?
  adId                    String?
  ctwaClid                String?
  attributionStatus       String?
  dedupeKey               String?   @unique
  eventOccurredAt         DateTime  @default(now())
  customerIdentityKey     String?
  businessSource          String    @default("paid")
  purchaseKind            String?
  valueSource             String?
  externalConnectorId     String?
  sourceEventId           String?
  sentAt                  DateTime?
  providerResponseSummary Json?
  customData              Json?
  valueCents              Int?
  currency                String?
  contentName             String?
  errorCode               String?
  errorMessage            String?
  jobId                   String?
  createdAt               DateTime  @default(now())

  workspace         Workspace?             @relation(fields: [workspaceId], references: [id])
  externalConnector ExternalDataConnector? @relation(fields: [externalConnectorId], references: [id], onDelete: SetNull)
  diagnosticEvents  DiagnosticEvent[]

  @@index([workspaceId, status, createdAt])
  @@index([workspaceId, eventOccurredAt])
  @@index([workspaceId, eventName, eventOccurredAt])
  @@index([workspaceId, adId])
  @@index([leadId])
  @@index([externalConnectorId, sourceEventId])
}

model ExternalDataConnector {
  id                        String    @id @default(cuid())
  workspaceId               String
  name                      String
  provider                  String
  status                    String    @default("draft")
  timezone                  String    @default("America/Sao_Paulo")
  sslMode                   String    @default("required")
  credentialsEncrypted      String
  credentialsIv             String
  credentialsTag            String
  syncEnabled               Boolean   @default(false)
  shadowMode                Boolean   @default(true)
  capiSendEnabled           Boolean   @default(false)
  purchaseAverageValueCents Int?
  defaultCurrency           String?   @default("BRL")
  lastConnectionTestAt      DateTime?
  lastConnectionStatus      String?
  lastSyncStartedAt         DateTime?
  lastSyncCompletedAt       DateTime?
  lastSyncStatus            String?
  lastSyncErrorCode         String?
  createdAt                 DateTime  @default(now())
  updatedAt                 DateTime  @updatedAt

  workspace        Workspace                 @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  cursors          ExternalSyncCursor[]
  ingestionRecords ExternalIngestionRecord[]
  conversionEvents ConversionEventLog[]

  @@index([workspaceId, status])
  @@index([syncEnabled, status, updatedAt])
}

model ExternalSyncCursor {
  id             String    @id @default(cuid())
  connectorId    String
  stream         String
  lastExternalId String?
  lastUpdatedAt  DateTime?
  lastSyncedAt   DateTime?
  metadata       Json?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  connector ExternalDataConnector @relation(fields: [connectorId], references: [id], onDelete: Cascade)

  @@unique([connectorId, stream])
  @@index([connectorId, lastSyncedAt])
}

model ExternalIngestionRecord {
  id                   String    @id @default(cuid())
  workspaceId          String
  connectorId          String
  stream               String
  externalRowId        String
  dedupeKey            String    @unique
  eventType            String?
  status               String
  occurredAt           DateTime?
  leadId               String?
  conversionEventLogId String?
  duplicateCount       Int       @default(0)
  errorCode            String?
  errorMessage         String?
  summaryPayload       Json?
  firstReceivedAt      DateTime  @default(now())
  lastReceivedAt       DateTime  @default(now())
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  workspace Workspace             @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  connector ExternalDataConnector @relation(fields: [connectorId], references: [id], onDelete: Cascade)

  @@index([connectorId, stream, externalRowId])
  @@index([workspaceId, status, occurredAt])
  @@index([conversionEventLogId])
}

model JobAttempt {
  id                String           @id @default(cuid())
  workspaceId       String?
  queueName         String
  jobId             String
  jobName           String
  attemptNumber     Int
  status            String
  scheduledAt       DateTime?
  startedAt         DateTime?
  finishedAt        DateTime?
  nextRetryAt       DateTime?
  source            DiagnosticSource
  relatedEntityType String?
  relatedEntityId   String?
  errorCode         String?
  errorMessage      String?
  summaryPayload    Json?
  createdAt         DateTime         @default(now())

  workspace        Workspace?        @relation(fields: [workspaceId], references: [id])
  diagnosticEvents DiagnosticEvent[]

  @@index([workspaceId, source, status, createdAt])
  @@index([jobId])
}

model DiagnosticEvent {
  id                   String             @id @default(cuid())
  workspaceId          String?
  source               DiagnosticSource
  eventType            String
  severity             DiagnosticSeverity
  status               String
  occurredAt           DateTime           @default(now())
  title                String
  message              String
  leadId               String?
  phoneHash            String?
  campaignId           String?
  adSetId              String?
  adId                 String?
  jobId                String?
  errorCode            String?
  summaryPayload       Json?
  webhookLogId         String?
  integrationLogId     String?
  conversionEventLogId String?
  jobAttemptId         String?
  createdAt            DateTime           @default(now())

  workspace          Workspace?          @relation(fields: [workspaceId], references: [id])
  webhookLog         WebhookLog?         @relation(fields: [webhookLogId], references: [id])
  integrationLog     IntegrationLog?     @relation(fields: [integrationLogId], references: [id])
  conversionEventLog ConversionEventLog? @relation(fields: [conversionEventLogId], references: [id])
  jobAttempt         JobAttempt?         @relation(fields: [jobAttemptId], references: [id])

  @@index([workspaceId, source, status, occurredAt])
  @@index([workspaceId, severity, occurredAt])
  @@index([eventType])
  @@index([leadId])
  @@index([phoneHash])
  @@index([campaignId])
  @@index([adSetId])
  @@index([adId])
  @@index([jobId])
}

model AuditLog {
  id            String   @id @default(cuid())
  workspaceId   String?
  actorUserId   String?
  actorType     String
  action        String
  targetType    String
  targetId      String
  reason        String?
  sourceIp      String?
  resultStatus  String
  beforeSummary Json?
  afterSummary  Json?
  createdAt     DateTime @default(now())

  workspace Workspace? @relation(fields: [workspaceId], references: [id])
  actorUser User?      @relation(fields: [actorUserId], references: [id])

  @@index([workspaceId, createdAt])
  @@index([actorUserId])
  @@index([targetType, targetId])
}

model SubscriptionPlan {
  id                            String   @id @default(cuid())
  name                          String
  slug                          String   @unique
  pricePerWhatsappInstanceCents Int
  active                        Boolean  @default(true)
  createdAt                     DateTime @default(now())
  updatedAt                     DateTime @updatedAt

  subscriptions WorkspaceSubscription[]
}

model WorkspaceSubscription {
  id                  String    @id @default(cuid())
  workspaceId         String
  planId              String?
  status              String
  activeInstances     Int       @default(0)
  asaasSubscriptionId String?
  currentPeriodEnd    DateTime?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  workspace Workspace         @relation(fields: [workspaceId], references: [id])
  plan      SubscriptionPlan? @relation(fields: [planId], references: [id])

  @@index([workspaceId, status])
  @@index([asaasSubscriptionId])
}

model PaymentCharge {
  id               String              @id @default(cuid())
  workspaceId      String
  provider         String              @default("asaas")
  externalChargeId String?
  status           PaymentChargeStatus @default(pending)
  amountCents      Int
  description      String
  checkoutUrl      String?
  dueAt            DateTime?
  paidAt           DateTime?
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt

  workspace  Workspace                   @relation(fields: [workspaceId], references: [id])
  activation WhatsappInstanceActivation?

  @@index([workspaceId, status])
  @@index([externalChargeId])
}

model SplitReceiver {
  id            String   @id @default(cuid())
  name          String
  walletId      String
  email         String?
  percentageBps Int
  active        Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  rules SplitRule[]
}

model SplitRule {
  id            String   @id @default(cuid())
  receiverId    String
  percentageBps Int
  active        Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  receiver SplitReceiver @relation(fields: [receiverId], references: [id])

  @@index([receiverId, active])
}

model WhatsappInstanceActivation {
  id                 String                           @id @default(cuid())
  workspaceId        String
  whatsappInstanceId String
  paymentChargeId    String                           @unique
  status             WhatsappInstanceActivationStatus @default(pending_payment)
  amountCents        Int
  createdAt          DateTime                         @default(now())
  activatedAt        DateTime?

  workspace        Workspace        @relation(fields: [workspaceId], references: [id])
  whatsappInstance WhatsappInstance @relation(fields: [whatsappInstanceId], references: [id])
  paymentCharge    PaymentCharge    @relation(fields: [paymentChargeId], references: [id])

  @@index([workspaceId, status])
  @@index([whatsappInstanceId])
}

model ConversionRule {
  id                 String                @id @default(cuid())
  workspaceId        String
  name               String
  triggerType        ConversionTriggerType
  triggerValue       String
  matchMode          ConversionMatchMode   @default(contains)
  eventName          String
  pixelId            String?
  defaultValueCents  Int?
  defaultCurrency    String?
  defaultContentName String?
  defaultItems       Json?
  active             Boolean               @default(true)
  createdAt          DateTime              @default(now())
  updatedAt          DateTime              @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id])

  @@index([workspaceId, active])
  @@index([workspaceId, triggerType, triggerValue])
}

model FunnelStageConfiguration {
  id                 String   @id @default(cuid())
  workspaceId        String
  eventName          String
  label              String
  position           Int
  visible            Boolean  @default(true)
  defaultValueCents  Int?
  defaultCurrency    String?
  defaultContentName String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, eventName])
  @@index([workspaceId, position])
}

model Lead {
  id                 String     @id @default(cuid())
  workspaceId        String
  whatsappInstanceId String?
  name               String?
  phoneDisplay       String?
  phoneHash          String
  status             LeadStatus @default(active)
  source             String?
  labels             String[]   @default([])
  campaignId         String?
  adSetId            String?
  adId               String?
  ctwaClid           String?
  ctwaSourceUrl      String?
  ctwaThumbnailUrl   String?
  firstMessageAt     DateTime?
  lastMessageAt      DateTime?
  createdAt          DateTime   @default(now())
  updatedAt          DateTime   @updatedAt

  workspace        Workspace         @relation(fields: [workspaceId], references: [id])
  whatsappInstance WhatsappInstance? @relation(fields: [whatsappInstanceId], references: [id])

  @@unique([workspaceId, phoneHash])
  @@index([workspaceId, status, lastMessageAt])
  @@index([workspaceId, firstMessageAt])
  @@index([workspaceId, createdAt])
  @@index([workspaceId, campaignId])
  @@index([workspaceId, adSetId])
  @@index([workspaceId, adId])
  @@index([workspaceId, ctwaClid])
}

model MetaIntegration {
  id                       String    @id @default(cuid())
  workspaceId              String    @unique
  status                   String    @default("connected")
  encryptedAccessToken     String
  tokenIv                  String
  tokenTag                 String
  tokenType                String?
  scopes                   String[]
  expiresAt                DateTime?
  lastConnectedAt          DateTime?
  selectedBusinessId       String?
  selectedAdAccountId      String?
  selectedPixelId          String?
  capiAccessTokenEncrypted String?
  capiTokenIv              String?
  capiTokenTag             String?
  createdAt                DateTime  @default(now())
  updatedAt                DateTime  @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id])

  @@index([status])
  @@index([selectedBusinessId])
  @@index([selectedAdAccountId])
  @@index([selectedPixelId])
}

model MetaAssetSnapshot {
  id          String    @id @default(cuid())
  workspaceId String
  snapshotKey String
  businessId  String?
  status      String    @default("connected")
  businesses  Json
  adAccounts  Json
  pixels      Json
  pages       Json
  syncError   String?
  syncedAt    DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id])

  @@unique([workspaceId, snapshotKey])
  @@index([workspaceId, businessId])
}

model MetaConversionDestination {
  id              String                          @id @default(cuid())
  workspaceId     String                          @unique
  pixelId         String
  pixelName       String
  pageId          String
  pageName        String
  status          MetaConversionDestinationStatus @default(configured)
  lastValidatedAt DateTime?
  validationError String?
  createdAt       DateTime                        @default(now())
  updatedAt       DateTime                        @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id])

  @@index([pixelId])
  @@index([pageId])
}

model MetaReportingAccount {
  id            String              @id @default(cuid())
  workspaceId   String
  businessId    String
  businessName  String
  adAccountId   String
  adAccountName String
  currency      String?
  timezoneName  String?
  active        Boolean             @default(true)
  syncStatus    MetaAssetSyncStatus @default(pending)
  lastSyncedAt  DateTime?
  lastSyncSince String?
  lastSyncUntil String?
  syncError     String?
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id])

  @@unique([workspaceId, adAccountId])
  @@index([workspaceId, active])
  @@index([workspaceId, active, businessId, adAccountId])
  @@index([businessId])
}

model MetaCampaign {
  id                       String                      @id @default(cuid())
  workspaceId              String
  businessId               String?
  adAccountId              String
  campaignId               String
  name                     String
  status                   String?
  effectiveStatus          String?
  objective                String?
  whatsappClassification   MetaWhatsappClassification  @default(not_whatsapp)
  classificationSource     String?
  classificationOverride   MetaWhatsappClassification?
  spendCents               Int                         @default(0)
  impressions              Int                         @default(0)
  clicks                   Int                         @default(0)
  metaConversationsStarted Int                         @default(0)
  lastSyncedAt             DateTime?
  createdAt                DateTime                    @default(now())
  updatedAt                DateTime                    @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id])

  @@unique([workspaceId, campaignId])
  @@index([workspaceId, adAccountId])
  @@index([workspaceId, status])
  @@index([workspaceId, businessId, adAccountId, whatsappClassification])
}

model MetaCampaignDailyInsight {
  id                       String   @id @default(cuid())
  workspaceId              String
  businessId               String
  adAccountId              String
  campaignId               String
  localDate                String
  spendCents               Int      @default(0)
  impressions              Int      @default(0)
  clicks                   Int      @default(0)
  metaConversationsStarted Int      @default(0)
  syncedAt                 DateTime @default(now())
  createdAt                DateTime @default(now())
  updatedAt                DateTime @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, campaignId, localDate])
  @@index([workspaceId, localDate])
  @@index([workspaceId, businessId, adAccountId, localDate])
  @@index([workspaceId, campaignId, localDate])
}

model MetaAdSet {
  id                       String                      @id @default(cuid())
  workspaceId              String
  businessId               String?
  adAccountId              String?
  campaignId               String
  adSetId                  String
  name                     String
  status                   String?
  effectiveStatus          String?
  destinationType          String?
  whatsappClassification   MetaWhatsappClassification  @default(not_whatsapp)
  classificationSource     String?
  classificationOverride   MetaWhatsappClassification?
  spendCents               Int                         @default(0)
  impressions              Int                         @default(0)
  clicks                   Int                         @default(0)
  metaConversationsStarted Int                         @default(0)
  lastSyncedAt             DateTime?
  createdAt                DateTime                    @default(now())
  updatedAt                DateTime                    @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id])

  @@unique([workspaceId, adSetId])
  @@index([workspaceId, campaignId])
  @@index([workspaceId, businessId, adAccountId, whatsappClassification])
  @@index([workspaceId, status])
}

model MetaAd {
  id                       String                      @id @default(cuid())
  workspaceId              String
  businessId               String?
  adAccountId              String?
  campaignId               String
  adSetId                  String
  adId                     String
  name                     String
  status                   String?
  effectiveStatus          String?
  destinationType          String?
  creativeId               String?
  callToActionType         String?
  whatsappClassification   MetaWhatsappClassification  @default(not_whatsapp)
  classificationSource     String?
  classificationOverride   MetaWhatsappClassification?
  spendCents               Int                         @default(0)
  impressions              Int                         @default(0)
  clicks                   Int                         @default(0)
  metaConversationsStarted Int                         @default(0)
  lastSyncedAt             DateTime?
  createdAt                DateTime                    @default(now())
  updatedAt                DateTime                    @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id])

  @@unique([workspaceId, adId])
  @@index([workspaceId, campaignId])
  @@index([workspaceId, adSetId])
  @@index([workspaceId, businessId, adAccountId, whatsappClassification])
  @@index([workspaceId, status])
}
