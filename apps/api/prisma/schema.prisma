generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum WorkspaceRole {
  owner
  admin
  member
}

enum PlatformRole {
  platform_owner
  platform_operator
}

enum AuthProvider {
  email
  google
}

enum WorkspaceInviteStatus {
  pending
  sent
  failed
  accepted
  revoked
  expired
}

enum WorkspaceOperationalStatus {
  active
  blocked
}

enum WhatsappInstanceStatus {
  pending_payment
  active
  disconnected
  suspended
  error
}

enum DiagnosticSource {
  meta
  uazapi
  umbler
  gupshup
  asaas
  external_mysql
  internal
}

enum DiagnosticSeverity {
  info
  warning
  error
  critical
}

enum PaymentChargeStatus {
  pending
  paid
  failed
  canceled
  expired
}

enum WhatsappInstanceActivationStatus {
  pending_payment
  active
  canceled
  expired
}

enum ConversionTriggerType {
  keyword
  whatsapp_label
}

enum ConversionMatchMode {
  contains
  exact
}

enum LeadStatus {
  new
  active
  qualified
  converted
  lost
}

enum MetaAssetSyncStatus {
  pending
  syncing
  synced
  error
}

enum MetaConversionDestinationStatus {
  needs_configuration
  configured
  error
}

enum MetaCredentialSource {
  oauth
  manual
}

enum MetaCredentialStatus {
  pending
  active
  validation_required
  expired
  revoked
  error
  paused
}

enum MetaBusinessConnectionStatus {
  pending
  active
  validation_required
  token_expired
  missing_permission
  destination_invalid
  error
  paused
}

enum MetaWhatsappClassification {
  auto_whatsapp
  creative_whatsapp
  detected_by_leads
  manual_include
  manual_exclude
  needs_review
  not_whatsapp
}

enum AuthActionTokenType {
  password_reset
  email_verification
  account_activation
}

enum InboundWebhookProvider {
  umbler
  gupshup
}

enum InboundWebhookParserReleaseStatus {
  observation_only
  certified
  retired
}

enum InboundWebhookConnectionStatus {
  observation
  production
  paused
}

enum InboundWebhookChannelStatus {
  discovered
  active
  paused
}

enum InboundWebhookDeliveryStatus {
  pending
  queued
  processing
  processed
  failed
}

enum InboundWebhookEventClassification {
  eligible_route_resolved
  eligible_route_unresolved
  ignored_no_ctwa
  ignored_outbound
  ignored_private
  unsupported_event
  invalid_payload
}

enum InboundWebhookReplayStatus {
  queued
  processing
  completed
  completed_with_failures
  failed
}

enum InboundWebhookReplayItemStatus {
  queued
  processing
  materialized
  duplicate
  skipped
  failed
}

enum InboundWebhookReplaySelection {
  canary_1
  canary_5
  canary_10
  remaining
}

model User {
  id              String        @id @default(cuid())
  email           String        @unique
  name            String?
  passwordHash    String?
  authProvider    AuthProvider  @default(email)
  googleId        String?       @unique
  emailVerifiedAt DateTime?
  platformRole    PlatformRole?
  lastWorkspaceId String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  memberships                      WorkspaceMember[]
  sessions                         AuthSession[]
  actionTokens                     AuthActionToken[]
  lastWorkspace                    Workspace?                    @relation("UserLastWorkspace", fields: [lastWorkspaceId], references: [id], onDelete: SetNull)
  metaOAuthStates                  MetaOAuthState[]
  auditLogs                        AuditLog[]
  createdMetaCredentials           MetaCredential[]              @relation("MetaCredentialCreator")
  createdMetaBusinessConnections   MetaBusinessConnection[]      @relation("MetaBusinessConnectionCreator")
  createdMetaDestinations          MetaConversionDestination[]   @relation("MetaConversionDestinationCreator")
  certifiedInboundWebhookParsers   InboundWebhookParserRelease[] @relation("InboundWebhookParserReleaseCertifier")
  createdInboundWebhookConnections InboundWebhookConnection[]    @relation("InboundWebhookConnectionCreator")
  createdInboundWebhookRoutes      InboundWebhookChannelRoute[]  @relation("InboundWebhookChannelRouteCreator")
  requestedInboundWebhookReplays   InboundWebhookReplayBatch[]   @relation("InboundWebhookReplayRequester")

  @@index([lastWorkspaceId])
}

model Workspace {
  id                String                     @id @default(cuid())
  name              String
  slug              String                     @unique
  asaasCustomerId   String?
  operationalStatus WorkspaceOperationalStatus @default(active)
  createdAt         DateTime                   @default(now())
  updatedAt         DateTime                   @updatedAt

  members                     WorkspaceMember[]
  invites                     WorkspaceInvite[]
  whatsappInstances           WhatsappInstance[]
  diagnosticEvents            DiagnosticEvent[]
  webhookLogs                 WebhookLog[]
  integrationLogs             IntegrationLog[]
  conversionEventLogs         ConversionEventLog[]
  jobAttempts                 JobAttempt[]
  auditLogs                   AuditLog[]
  subscriptions               WorkspaceSubscription[]
  paymentCharges              PaymentCharge[]
  whatsappInstanceActivations WhatsappInstanceActivation[]
  conversionRules             ConversionRule[]
  funnelStageConfigurations   FunnelStageConfiguration[]
  leads                       Lead[]
  metaIntegration             MetaIntegration?
  metaCredentials             MetaCredential[]
  metaBusinessConnections     MetaBusinessConnection[]
  metaAssetSnapshots          MetaAssetSnapshot[]
  metaConversionDestinations  MetaConversionDestination[]
  metaReportingAccounts       MetaReportingAccount[]
  metaCampaigns               MetaCampaign[]
  metaCampaignDailyInsights   MetaCampaignDailyInsight[]
  metaAdSets                  MetaAdSet[]
  metaAdSetDailyInsights      MetaAdSetDailyInsight[]
  metaAds                     MetaAd[]
  metaAdDailyInsights         MetaAdDailyInsight[]
  metaOAuthStates             MetaOAuthState[]
  externalDataConnectors      ExternalDataConnector[]
  externalIngestionRecords    ExternalIngestionRecord[]
  activeSessions              AuthSession[]                @relation("AuthSessionActiveWorkspace")
  supportSessions             AuthSession[]                @relation("AuthSessionSupportWorkspace")
  lastSelectedByUsers         User[]                       @relation("UserLastWorkspace")
  actionTokens                AuthActionToken[]
  inboundWebhookConnections   InboundWebhookConnection[]
  inboundWebhookChannels      InboundWebhookChannel[]
  inboundWebhookChannelRoutes InboundWebhookChannelRoute[]
  inboundWebhookDeliveries    InboundWebhookDelivery[]
  inboundWebhookEvents        InboundWebhookEvent[]
  inboundWebhookReplayBatches InboundWebhookReplayBatch[]
  inboundWebhookReplayItems   InboundWebhookReplayItem[]

  @@index([asaasCustomerId])
  @@index([operationalStatus])
}

model WorkspaceMember {
  id               String        @id @default(cuid())
  workspaceId      String
  userId           String
  role             WorkspaceRole
  canManageMembers Boolean       @default(false)
  createdAt        DateTime      @default(now())

  workspace Workspace @relation(fields: [workspaceId], references: [id])
  user      User      @relation(fields: [userId], references: [id])

  @@unique([workspaceId, userId])
  @@index([userId])
}

model WhatsappInstance {
  id                     String                 @id @default(cuid())
  workspaceId            String
  name                   String
  provider               String
  providerInstanceId     String?
  providerTokenEncrypted String?
  providerTokenIv        String?
  providerTokenTag       String?
  webhookTokenHash       String?
  status                 WhatsappInstanceStatus @default(pending_payment)
  createdAt              DateTime               @default(now())
  updatedAt              DateTime               @updatedAt

  workspace   Workspace                    @relation(fields: [workspaceId], references: [id])
  activations WhatsappInstanceActivation[]
  leads       Lead[]

  @@index([workspaceId])
  @@index([providerInstanceId])
}

model AuthSession {
  id                        String    @id @default(cuid())
  userId                    String
  activeWorkspaceId         String?
  supportWorkspaceId        String?
  supportWorkspaceStartedAt DateTime?
  refreshHash               String    @unique
  userAgent                 String?
  ipAddress                 String?
  expiresAt                 DateTime
  revokedAt                 DateTime?
  createdAt                 DateTime  @default(now())

  user             User       @relation(fields: [userId], references: [id])
  activeWorkspace  Workspace? @relation("AuthSessionActiveWorkspace", fields: [activeWorkspaceId], references: [id], onDelete: SetNull)
  supportWorkspace Workspace? @relation("AuthSessionSupportWorkspace", fields: [supportWorkspaceId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([userId, activeWorkspaceId])
  @@index([activeWorkspaceId])
  @@index([supportWorkspaceId])
}

model AuthActionToken {
  id          String              @id @default(cuid())
  userId      String
  workspaceId String?
  type        AuthActionTokenType
  tokenHash   String              @unique
  expiresAt   DateTime
  usedAt      DateTime?
  createdAt   DateTime            @default(now())

  user      User       @relation(fields: [userId], references: [id])
  workspace Workspace? @relation(fields: [workspaceId], references: [id], onDelete: SetNull)

  @@index([userId, type, usedAt])
  @@index([workspaceId, type, usedAt])
  @@index([type, expiresAt])
}

model MetaOAuthState {
  id          String    @id @default(cuid())
  stateHash   String    @unique
  workspaceId String
  userId      String
  expiresAt   DateTime
  consumedAt  DateTime?
  createdAt   DateTime  @default(now())

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([workspaceId, consumedAt, expiresAt])
  @@index([userId, consumedAt, expiresAt])
}

model WorkspaceInvite {
  id          String                @id @default(cuid())
  workspaceId String
  email       String
  role        WorkspaceRole
  status      WorkspaceInviteStatus @default(pending)
  tokenHash   String                @unique
  expiresAt   DateTime
  acceptedAt  DateTime?
  createdAt   DateTime              @default(now())

  workspace Workspace @relation(fields: [workspaceId], references: [id])

  @@index([workspaceId, email])
}

model WebhookLog {
  id              String           @id @default(cuid())
  workspaceId     String?
  source          DiagnosticSource
  eventType       String
  externalEventId String?
  status          String
  receivedAt      DateTime         @default(now())
  processedAt     DateTime?
  leadId          String?
  phoneHash       String?
  campaignId      String?
  adSetId         String?
  adId            String?
  jobId           String?
  errorCode       String?
  errorMessage    String?
  summaryPayload  Json?
  rawPayloadRef   String?
  idempotencyKey  String?          @unique

  workspace        Workspace?        @relation(fields: [workspaceId], references: [id])
  diagnosticEvents DiagnosticEvent[]

  @@index([workspaceId, source, status, receivedAt])
}

model IntegrationLog {
  id                   String           @id @default(cuid())
  workspaceId          String?
  source               DiagnosticSource
  operation            String
  status               String
  startedAt            DateTime         @default(now())
  finishedAt           DateTime?
  durationMs           Int?
  requestSummary       Json?
  responseSummary      Json?
  httpStatus           Int?
  providerRequestId    String?
  providerErrorCode    String?
  providerErrorMessage String?
  leadId               String?
  campaignId           String?
  adSetId              String?
  adId                 String?
  jobId                String?

  workspace        Workspace?        @relation(fields: [workspaceId], references: [id])
  diagnosticEvents DiagnosticEvent[]

  @@index([workspaceId, source, status, startedAt])
  @@index([providerRequestId])
}

model ConversionEventLog {
  id                          String    @id @default(cuid())
  workspaceId                 String?
  leadId                      String?
  phoneHash                   String?
  sourceTrigger               String
  eventName                   String
  status                      String
  pixelId                     String?
  pageId                      String?
  eventId                     String?
  metaAccountId               String?
  campaignId                  String?
  adSetId                     String?
  adId                        String?
  ctwaClid                    String?
  attributionStatus           String?
  dedupeKey                   String?   @unique
  eventOccurredAt             DateTime  @default(now())
  customerIdentityKey         String?
  businessSource              String    @default("paid")
  purchaseKind                String?
  valueSource                 String?
  externalConnectorId         String?
  sourceEventId               String?
  sentAt                      DateTime?
  sourcePayload               Json?
  providerRequestPayload      Json?
  providerResponseSummary     Json?
  customData                  Json?
  valueCents                  Int?
  currency                    String?
  contentName                 String?
  errorCode                   String?
  errorMessage                String?
  jobId                       String?
  metaBusinessConnectionId    String?
  metaConversionDestinationId String?
  createdAt                   DateTime  @default(now())

  workspace                 Workspace?                 @relation(fields: [workspaceId], references: [id])
  externalConnector         ExternalDataConnector?     @relation(fields: [externalConnectorId], references: [id], onDelete: SetNull)
  metaBusinessConnection    MetaBusinessConnection?    @relation(fields: [metaBusinessConnectionId], references: [id], onDelete: SetNull)
  metaConversionDestination MetaConversionDestination? @relation(fields: [metaConversionDestinationId], references: [id], onDelete: SetNull)
  diagnosticEvents          DiagnosticEvent[]

  @@index([workspaceId, status, createdAt])
  @@index([workspaceId, eventOccurredAt])
  @@index([workspaceId, eventName, eventOccurredAt])
  @@index([workspaceId, adId])
  @@index([workspaceId, metaBusinessConnectionId])
  @@index([workspaceId, metaConversionDestinationId])
  @@index([leadId])
  @@index([externalConnectorId, sourceEventId])
}

model ExternalDataConnector {
  id                        String    @id @default(cuid())
  workspaceId               String
  name                      String
  provider                  String
  status                    String    @default("draft")
  timezone                  String    @default("America/Sao_Paulo")
  sslMode                   String    @default("required")
  credentialsEncrypted      String
  credentialsIv             String
  credentialsTag            String
  syncEnabled               Boolean   @default(false)
  shadowMode                Boolean   @default(true)
  capiSendEnabled           Boolean   @default(false)
  purchaseAverageValueCents Int?
  defaultCurrency           String?   @default("BRL")
  lastConnectionTestAt      DateTime?
  lastConnectionStatus      String?
  lastSyncStartedAt         DateTime?
  lastSyncCompletedAt       DateTime?
  lastSyncStatus            String?
  lastSyncErrorCode         String?
  createdAt                 DateTime  @default(now())
  updatedAt                 DateTime  @updatedAt

  workspace        Workspace                 @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  cursors          ExternalSyncCursor[]
  ingestionRecords ExternalIngestionRecord[]
  conversionEvents ConversionEventLog[]
  capiCutovers     ExternalCapiCutover[]

  @@index([workspaceId, status])
  @@index([syncEnabled, status, updatedAt])
}

model ExternalCapiCutover {
  id                 String    @id @default(cuid())
  workspaceId        String
  connectorId        String
  eventType          String
  status             String    @default("active")
  activatedAt        DateTime
  activatedByUserId  String
  shadowArchivedRows Int       @default(0)
  rolledBackAt       DateTime?
  rolledBackByUserId String?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  connector ExternalDataConnector @relation(fields: [connectorId], references: [id], onDelete: Cascade)

  @@index([connectorId, status])
  @@index([workspaceId, eventType, activatedAt])
}

model ExternalSyncCursor {
  id             String    @id @default(cuid())
  connectorId    String
  stream         String
  lastExternalId String?
  lastUpdatedAt  DateTime?
  lastSyncedAt   DateTime?
  metadata       Json?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  connector ExternalDataConnector @relation(fields: [connectorId], references: [id], onDelete: Cascade)

  @@unique([connectorId, stream])
  @@index([connectorId, lastSyncedAt])
}

model ExternalIngestionRecord {
  id                   String    @id @default(cuid())
  workspaceId          String
  connectorId          String
  stream               String
  externalRowId        String
  dedupeKey            String    @unique
  eventType            String?
  status               String
  occurredAt           DateTime?
  leadId               String?
  conversionEventLogId String?
  duplicateCount       Int       @default(0)
  errorCode            String?
  errorMessage         String?
  summaryPayload       Json?
  firstReceivedAt      DateTime  @default(now())
  lastReceivedAt       DateTime  @default(now())
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  workspace Workspace             @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  connector ExternalDataConnector @relation(fields: [connectorId], references: [id], onDelete: Cascade)

  @@index([connectorId, stream, externalRowId])
  @@index([workspaceId, status, occurredAt])
  @@index([conversionEventLogId])
}

model JobAttempt {
  id                String           @id @default(cuid())
  workspaceId       String?
  queueName         String
  jobId             String
  jobName           String
  attemptNumber     Int
  status            String
  scheduledAt       DateTime?
  startedAt         DateTime?
  finishedAt        DateTime?
  nextRetryAt       DateTime?
  source            DiagnosticSource
  relatedEntityType String?
  relatedEntityId   String?
  errorCode         String?
  errorMessage      String?
  summaryPayload    Json?
  createdAt         DateTime         @default(now())

  workspace        Workspace?        @relation(fields: [workspaceId], references: [id])
  diagnosticEvents DiagnosticEvent[]

  @@index([workspaceId, source, status, createdAt])
  @@index([jobId])
}

model DiagnosticEvent {
  id                   String             @id @default(cuid())
  workspaceId          String?
  source               DiagnosticSource
  eventType            String
  severity             DiagnosticSeverity
  status               String
  occurredAt           DateTime           @default(now())
  title                String
  message              String
  leadId               String?
  phoneHash            String?
  campaignId           String?
  adSetId              String?
  adId                 String?
  jobId                String?
  errorCode            String?
  summaryPayload       Json?
  webhookLogId         String?
  integrationLogId     String?
  conversionEventLogId String?
  jobAttemptId         String?
  createdAt            DateTime           @default(now())

  workspace          Workspace?          @relation(fields: [workspaceId], references: [id])
  webhookLog         WebhookLog?         @relation(fields: [webhookLogId], references: [id])
  integrationLog     IntegrationLog?     @relation(fields: [integrationLogId], references: [id])
  conversionEventLog ConversionEventLog? @relation(fields: [conversionEventLogId], references: [id])
  jobAttempt         JobAttempt?         @relation(fields: [jobAttemptId], references: [id])

  @@index([workspaceId, source, status, occurredAt])
  @@index([workspaceId, severity, occurredAt])
  @@index([eventType])
  @@index([leadId])
  @@index([phoneHash])
  @@index([campaignId])
  @@index([adSetId])
  @@index([adId])
  @@index([jobId])
}

model AuditLog {
  id            String   @id @default(cuid())
  workspaceId   String?
  actorUserId   String?
  actorType     String
  action        String
  targetType    String
  targetId      String
  reason        String?
  sourceIp      String?
  resultStatus  String
  beforeSummary Json?
  afterSummary  Json?
  createdAt     DateTime @default(now())

  workspace Workspace? @relation(fields: [workspaceId], references: [id])
  actorUser User?      @relation(fields: [actorUserId], references: [id])

  @@index([workspaceId, createdAt])
  @@index([actorUserId])
  @@index([targetType, targetId])
}

model SubscriptionPlan {
  id                            String   @id @default(cuid())
  name                          String
  slug                          String   @unique
  pricePerWhatsappInstanceCents Int
  active                        Boolean  @default(true)
  createdAt                     DateTime @default(now())
  updatedAt                     DateTime @updatedAt

  subscriptions WorkspaceSubscription[]
}

model WorkspaceSubscription {
  id                  String    @id @default(cuid())
  workspaceId         String
  planId              String?
  status              String
  activeInstances     Int       @default(0)
  asaasSubscriptionId String?
  currentPeriodEnd    DateTime?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  workspace Workspace         @relation(fields: [workspaceId], references: [id])
  plan      SubscriptionPlan? @relation(fields: [planId], references: [id])

  @@index([workspaceId, status])
  @@index([asaasSubscriptionId])
}

model PaymentCharge {
  id               String              @id @default(cuid())
  workspaceId      String
  provider         String              @default("asaas")
  externalChargeId String?
  status           PaymentChargeStatus @default(pending)
  amountCents      Int
  description      String
  checkoutUrl      String?
  dueAt            DateTime?
  paidAt           DateTime?
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt

  workspace  Workspace                   @relation(fields: [workspaceId], references: [id])
  activation WhatsappInstanceActivation?

  @@index([workspaceId, status])
  @@index([externalChargeId])
}

model SplitReceiver {
  id            String   @id @default(cuid())
  name          String
  walletId      String
  email         String?
  percentageBps Int
  active        Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  rules SplitRule[]
}

model SplitRule {
  id            String   @id @default(cuid())
  receiverId    String
  percentageBps Int
  active        Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  receiver SplitReceiver @relation(fields: [receiverId], references: [id])

  @@index([receiverId, active])
}

model WhatsappInstanceActivation {
  id                 String                           @id @default(cuid())
  workspaceId        String
  whatsappInstanceId String
  paymentChargeId    String                           @unique
  status             WhatsappInstanceActivationStatus @default(pending_payment)
  amountCents        Int
  createdAt          DateTime                         @default(now())
  activatedAt        DateTime?

  workspace        Workspace        @relation(fields: [workspaceId], references: [id])
  whatsappInstance WhatsappInstance @relation(fields: [whatsappInstanceId], references: [id])
  paymentCharge    PaymentCharge    @relation(fields: [paymentChargeId], references: [id])

  @@index([workspaceId, status])
  @@index([whatsappInstanceId])
}

model ConversionRule {
  id                 String                @id @default(cuid())
  workspaceId        String
  name               String
  triggerType        ConversionTriggerType
  triggerValue       String
  matchMode          ConversionMatchMode   @default(contains)
  eventName          String
  pixelId            String?
  defaultValueCents  Int?
  defaultCurrency    String?
  defaultContentName String?
  defaultItems       Json?
  active             Boolean               @default(true)
  createdAt          DateTime              @default(now())
  updatedAt          DateTime              @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id])

  @@index([workspaceId, active])
  @@index([workspaceId, triggerType, triggerValue])
}

model FunnelStageConfiguration {
  id                 String   @id @default(cuid())
  workspaceId        String
  eventName          String
  label              String
  position           Int
  visible            Boolean  @default(true)
  defaultValueCents  Int?
  defaultCurrency    String?
  defaultContentName String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, eventName])
  @@index([workspaceId, position])
}

model Lead {
  id                 String     @id @default(cuid())
  workspaceId        String
  whatsappInstanceId String?
  name               String?
  phoneDisplay       String?
  phoneHash          String
  status             LeadStatus @default(active)
  source             String?
  labels             String[]   @default([])
  campaignId         String?
  adSetId            String?
  adId               String?
  ctwaClid           String?
  ctwaSourceUrl      String?
  ctwaThumbnailUrl   String?
  firstMessageAt     DateTime?
  lastMessageAt      DateTime?
  createdAt          DateTime   @default(now())
  updatedAt          DateTime   @updatedAt

  workspace        Workspace         @relation(fields: [workspaceId], references: [id])
  whatsappInstance WhatsappInstance? @relation(fields: [whatsappInstanceId], references: [id])

  @@unique([workspaceId, phoneHash])
  @@index([workspaceId, status, lastMessageAt])
  @@index([workspaceId, firstMessageAt])
  @@index([workspaceId, createdAt])
  @@index([workspaceId, campaignId])
  @@index([workspaceId, adSetId])
  @@index([workspaceId, adId])
  @@index([workspaceId, ctwaClid])
}

model MetaIntegration {
  id                             String    @id @default(cuid())
  workspaceId                    String    @unique
  status                         String    @default("connected")
  encryptedAccessToken           String
  tokenIv                        String
  tokenTag                       String
  tokenType                      String?
  scopes                         String[]
  expiresAt                      DateTime?
  lastConnectedAt                DateTime?
  selectedBusinessId             String?
  selectedAdAccountId            String?
  selectedPixelId                String?
  capiAccessTokenEncrypted       String?
  capiTokenIv                    String?
  capiTokenTag                   String?
  primaryConversionDestinationId String?
  advancedRoutingEnabled         Boolean   @default(false)
  createdAt                      DateTime  @default(now())
  updatedAt                      DateTime  @updatedAt

  workspace                    Workspace                  @relation(fields: [workspaceId], references: [id])
  primaryConversionDestination MetaConversionDestination? @relation("MetaIntegrationPrimaryDestination", fields: [primaryConversionDestinationId], references: [id], onDelete: SetNull)

  @@index([status])
  @@index([selectedBusinessId])
  @@index([selectedAdAccountId])
  @@index([selectedPixelId])
  @@index([primaryConversionDestinationId])
  @@index([advancedRoutingEnabled])
}

model MetaCredential {
  id                   String               @id @default(cuid())
  workspaceId          String
  source               MetaCredentialSource
  label                String
  encryptedAccessToken String
  tokenIv              String
  tokenTag             String
  encryptionKeyVersion Int                  @default(1)
  fingerprint          String
